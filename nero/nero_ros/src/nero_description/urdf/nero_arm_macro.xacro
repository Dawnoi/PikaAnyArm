<?xml version="1.0" encoding="utf-8"?>
<!--
  中文说明：
  - 本文件提供一个“可复用的 Nero 单臂”xacro 宏 `nero_arm`，用于在顶层模型里实例化多只机械臂（例如双臂）。
  - 该宏由 `nero_description.urdf` 改写而来，核心目的：
    - 去掉原先的 `world` 与 `world_to_base_link`，避免把单臂强行固定到 world
    - 通过 `prefix` 给所有 link/joint 加前缀，避免多实例时名字冲突（例如 `left_joint1`、`right_joint1`）
    - 通过 `parent_link` 与 `origin` 参数，让单臂基座 `base_link` 可以被挂载到任意父 link（如 `body`）
  - 宏参数：
    - `prefix`：字符串前缀（建议 `left_` / `right_`）
    - `parent_link`：要挂载到的父 link 名称
    - `origin`：一个 `<origin xyz="..." rpy="..."/>` 块，描述 `parent_link -> ${prefix}base_link` 的固定变换
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="nero_arm" params="prefix parent_link joint1_lower:=-2.70526 joint1_upper:=2.70526 joint2_lower:=-1.0471975512 joint2_upper:=1.74 joint3_lower:=-2.75 joint3_upper:=2.75 joint4_lower:=-1.01 joint4_upper:=2.14 joint5_lower:=-2.75 joint5_upper:=2.75 *origin">
    <!-- 将单臂基座挂载到父 link（装配入口） -->
    <joint name="${prefix}mount_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="-0.00319465997 -0.00005467608 0.04321758463" rpy="0 0 0"/>
        <mass value="1.06458435"/>
        <inertia ixx="0.00102659855152" ixy="0.00000186219753" ixz="-0.00000295298037" iyy="0.00114399299508" iyz="-0.00000078763492" izz="0.00090872933022"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/base_link.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/base_link.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link1">
      <inertial>
        <origin xyz="-0.00076810578 -0.00005718031 -0.00686372765" rpy="0 0 0"/>
        <mass value="0.76710504"/>
        <inertia ixx="0.00066689512233" ixy="0.00000273938306" ixz="0.00001463284987" iyy="0.00054501235592" iyz="0.00000183168344" izz="0.00051509465737"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link1.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link1.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint1" type="revolute">
      <origin xyz="0 0 0.138" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link1"/>
      <axis xyz="0 0 1"/>
      <limit lower="${joint1_lower}" upper="${joint1_upper}" effort="100" velocity="5"/>
    </joint>

    <link name="${prefix}link2">
      <inertial>
        <origin xyz="0.00079686657 -0.07890325930 0.00111849422" rpy="0 0 0"/>
        <mass value="0.69381908"/>
        <inertia ixx="0.00201093857656" ixy="-0.00002399426785" ixz="-0.00000072824714" iyy="0.00063544232555" iyz="0.00005831284343" izz="0.00181943989593"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link2.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link2.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint2" type="revolute">
      <origin xyz="0 0 0" rpy="1.5707963  3.1415926 0"/>
      <parent link="${prefix}link1"/>
      <child link="${prefix}link2"/>
      <axis xyz="0 0 1"/>
      <limit lower="${joint2_lower}" upper="${joint2_upper}" effort="100" velocity="5"/>
    </joint>

    <link name="${prefix}link3">
      <inertial>
        <origin xyz="0.00014513363 -0.00121378766 -0.04861136795" rpy="0 0 0"/>
        <mass value="0.67246544"/>
        <inertia ixx="0.00343229961910" ixy="-0.00000026976739" ixz="0.00000305078107" iyy="0.00338662526897" iyz="-0.00003550220027" izz="0.00028853579710"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link3.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link3.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint3" type="revolute">
      <origin xyz="0 -0.31 0" rpy="-1.5707963  0 3.1415926926"/>
      <parent link="${prefix}link2"/>
      <child link="${prefix}link3"/>
      <axis xyz="0 0 1"/>
      <!-- joint3：由 joint3_lower / joint3_upper 传入（默认 -2.75..2.75 rad） -->
      <limit lower="${joint3_lower}" upper="${joint3_upper}" effort="100" velocity="5"/>
    </joint>

    <link name="${prefix}link4">
      <inertial>
        <origin xyz="-0.00031334623 -0.05675192422 0.00076056133" rpy="0 0 0"/>
        <mass value="0.48451414"/>
        <inertia ixx="0.00050386693505" ixy="-0.00000529675237" ixz="0.00000006134740" iyy="0.00023502068202" iyz="0.00001815932566" izz="0.00040149523118"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link4.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link4.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint4" type="revolute">
      <origin xyz="0 0 0" rpy="-1.5707963  0 3.1415926926"/>
      <parent link="${prefix}link3"/>
      <child link="${prefix}link4"/>
      <axis xyz="0 0 1"/>
      <!-- joint4：由 joint4_lower / joint4_upper 传入 -->
      <limit lower="${joint4_lower}" upper="${joint4_upper}" effort="100" velocity="5"/>
    </joint>

    <link name="${prefix}link5">
      <inertial>
        <origin xyz="0.00265591357 0.00201195753 -0.11620855434" rpy="0 0 0"/>
        <mass value="0.58368405"/>
        <inertia ixx="0.00089537686723" ixy="0.00000648218232" ixz="-0.00001463346849" iyy="0.00085866122972" iyz="-0.00004035185637" izz="0.00021774946532"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link5.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link5.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint5" type="revolute">
      <origin xyz="0 -0.27001 0" rpy="1.5707963  -1.5707963  0"/>
      <parent link="${prefix}link4"/>
      <child link="${prefix}link5"/>
      <axis xyz="0 0 1"/>
      <limit lower="${joint5_lower}" upper="${joint5_upper}" effort="100" velocity="5"/>
    </joint>

    <link name="${prefix}link6">
      <inertial>
        <origin xyz="0.00009501505 0.00107831174 -0.00019110990" rpy="0 0 0"/>
        <mass value="0.3140406"/>
        <inertia ixx="0.00006027211661" ixy="-0.00000024650903" ixz="0.00000015701294" iyy="0.00004699514792" iyz="0.00000004170875" izz="0.00005756771792"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link6.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link6.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint6" type="revolute">
      <origin xyz="0 0 0" rpy="1.5707963  -1.5707963  0"/>
      <parent link="${prefix}link5"/>
      <child link="${prefix}link6"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.73" upper="0.95" effort="100" velocity="5"/>
    </joint>

    <link name="${prefix}link7">
      <inertial>
        <origin xyz="-0.00014000 -0.00010000 -0.00275000" rpy="0 0 0"/>
        <mass value="0.000001"/>
        <inertia ixx="1.1000000000000001e-07" ixy="0" ixz="0" iyy="1.1000000000000001e-07" iyz="0" izz="1.9999999999999999e-07"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/link7.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/link7.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}joint7" type="revolute">
      <origin xyz="0 -0.0235 0" rpy="1.5707963 0 0"/>
      <parent link="${prefix}link6"/>
      <child link="${prefix}link7"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5707963" upper="1.5707963" effort="100" velocity="5"/>
    </joint>
  </xacro:macro>
</robot>
