<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    可复用夹爪宏：
    - prefix: 命名前缀（建议 left_/right_）
    - parent_link: 挂载父链接（双臂场景下通常是 ${prefix}link7）
    - origin: parent_link -> ${prefix}gripper_flange 的固定变换
  -->
  <xacro:macro name="nero_gripper" params="prefix parent_link *origin">
    <link name="${prefix}gripper_flange">
      <inertial>
        <origin xyz="0.0 0.0 -0.00032" rpy="0 0 0"/>
        <mass value="0.04771096"/>
        <inertia ixx="2.697e-05" ixy="0" ixz="0" iyy="4.311e-05" iyz="0" izz="2.479e-05"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/gripper_flange.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/gripper_flange.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}gripper_flange_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${prefix}gripper_flange"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}gripper_base">
      <inertial>
        <origin xyz="-0.000183807162235591 8.05033155577911E-05 0.0321436689908876" rpy="0 0 0"/>
        <mass value="0.45"/>
        <inertia ixx="0.00092934" ixy="0.00000034" ixz="-0.00000738" iyy="0.00071447" iyz="0.00000005" izz="0.00039442"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/gripper_base.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/gripper_base.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}gripper_base_joint" type="fixed">
      <origin xyz="0 0 0.0055" rpy="0 0 0"/>
      <parent link="${prefix}gripper_flange"/>
      <child link="${prefix}gripper_base"/>
    </joint>

    <link name="${prefix}gripper_link1">
      <inertial>
        <origin xyz="0.00065123185041968 -0.0491929869131989 0.00972258769184025" rpy="0 0 0"/>
        <mass value="0.025"/>
        <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021" iyy="0.00000781" iyz="-0.00001372" izz="0.0000747"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/gripper_link1.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/gripper_link1.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}gripper_joint1" type="prismatic">
      <origin xyz="0 0 0.1358" rpy="1.5707963 0 3.1415926"/>
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}gripper_link1"/>
      <axis xyz="0 0 1"/>
      <limit lower="0" upper="0.05" effort="10" velocity="3"/>
    </joint>

    <link name="${prefix}gripper_link2">
      <inertial>
        <origin xyz="0.00065123185041968 -0.0491929869131989 0.00972258769184025" rpy="0 0 0"/>
        <mass value="0.025"/>
        <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021" iyy="0.00000781" iyz="-0.00001372" izz="0.0000747"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/dae/gripper_link2.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://nero_description/meshes/gripper_link2.stl"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}gripper_joint2" type="prismatic">
      <origin xyz="0 0 0.1358" rpy="1.5707963 0 0"/>
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}gripper_link2"/>
      <axis xyz="0 0 -1"/>
      <limit lower="-0.05" upper="0" effort="10" velocity="3"/>
    </joint>
  </xacro:macro>
</robot>
